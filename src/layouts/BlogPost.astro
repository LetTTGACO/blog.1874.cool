---
import { render, type CollectionEntry } from "astro:content";

import BaseLayout from "./Base.astro";
import BlogHero from "@/components/blog/Hero";
import TOC from "@/components/blog/TOC";
// import WebMentions from "@/components/blog/webmentions/index";
import Comment from "@/components/Comment";
import { getStaleNoticeType } from "@/utils/staleNotice";

interface Props {
	post: CollectionEntry<"post">;
	showStaleNotice?: boolean;
}

const { post, showStaleNotice = true } = Astro.props;
const {
	data: { title, description = "", date, updated },
} = post;
// const socialImage = ogImage ?? `/og-image/${slug}.png`;
const articleDate = updated?.toISOString() ?? date.toISOString();
const staleNoticeType = showStaleNotice ? getStaleNoticeType(post) : undefined;
const { headings } = await render(post);
---

<BaseLayout meta={{ title, description, articleDate }}>
	<div class="gap-x-10 lg:flex lg:items-start">
		{!!headings.length && <TOC headings={headings} />}
		<article class="flex-grow break-words" data-pagefind-body>
			<div id="blog-hero"><BlogHero content={post} /></div>
			<div
				class="prose prose-sm prose-cactus mt-12 prose-headings:font-semibold prose-headings:text-accent-2 prose-headings:before:absolute prose-headings:before:-ms-4 prose-headings:before:text-accent prose-headings:before:content-['#'] prose-th:before:content-none"
			>
				{
					staleNoticeType && (
						<blockquote>
							<p>
								<strong>时效性提醒</strong>
							</p>
							{staleNoticeType === "vibecoding" ? (
								<p>
									当你看到这个提醒，说明这篇文章发布已超过一个月。Vibe Coding
									时代，模型、工具和工作流变化太快，文中的做法可能已经过时，我也未必还在使用。请把它当作当时的实践记录，谨慎参考。
								</p>
							) : (
								<p>
									当你看到这个提醒，说明这篇文章发布已超过一年。技术版本、命令和平台界面可能已经变化，文中的做法可能已经过时，我也未必还在使用。请把它当作当时的实践记录，谨慎参考。
								</p>
							)}
						</blockquote>
					)
				}
				<slot />
				<!--<WebMentions />-->
				<Comment />
			</div>
		</article>
	</div>
	<button
		id="to-top-btn"
		class="z-90 fixed bottom-8 end-4 flex h-10 w-10 translate-y-28 items-center justify-center rounded-full border-2 border-transparent bg-zinc-200 text-3xl opacity-0 transition-all duration-300 hover:border-zinc-400 data-[show=true]:translate-y-0 data-[show=true]:opacity-100 dark:bg-zinc-700 sm:end-8 sm:h-12 sm:w-12"
		aria-label="Back to Top"
		data-show="false"
		><svg
			xmlns="http://www.w3.org/2000/svg"
			aria-hidden="true"
			focusable="false"
			fill="none"
			viewBox="0 0 24 24"
			stroke-width="2"
			stroke="currentColor"
			class="h-6 w-6"
		>
			<path stroke-linecap="round" stroke-linejoin="round" d="M4.5 15.75l7.5-7.5 7.5 7.5"></path>
		</svg>
	</button>
</BaseLayout>

<script>
	import Panzoom from "@panzoom/panzoom";

	const zoomViewerOverlayId = "content-zoom-overlay";
	const zoomViewerAnimationMs = 180;
	let destroyActiveZoomViewer: (() => void) | null = null;

	function getSvgViewBoxWidth(svg: SVGSVGElement): number {
		const viewBox = svg.getAttribute("viewBox")?.split(/\s+/).map(Number);
		if (viewBox?.length === 4 && typeof viewBox[2] === "number" && Number.isFinite(viewBox[2])) {
			return viewBox[2];
		}

		return svg.clientWidth || svg.getBoundingClientRect().width;
	}

	function waitForImage(image: HTMLImageElement) {
		if (image.complete) {
			return Promise.resolve();
		}

		return new Promise<void>((resolve) => {
			image.addEventListener("load", () => resolve(), { once: true });
			image.addEventListener("error", () => resolve(), { once: true });
		});
	}

	function closeZoomViewer({ animate = true } = {}) {
		destroyActiveZoomViewer?.();
		destroyActiveZoomViewer = null;

		const overlay = document.getElementById(zoomViewerOverlayId);
		if (overlay && animate) {
			overlay.classList.remove("is-open");
			overlay.classList.add("is-closing");
			window.setTimeout(() => overlay.remove(), zoomViewerAnimationMs);
		} else {
			overlay?.remove();
		}

		document.documentElement.classList.remove("zoom-viewer-open");
		document.removeEventListener("keydown", onZoomViewerKeydown);
	}

	function onZoomViewerKeydown(event: KeyboardEvent) {
		if (event.key === "Escape") {
			closeZoomViewer();
		}
	}

	async function openZoomViewer(content: HTMLElement | SVGSVGElement, label: string) {
		closeZoomViewer({ animate: false });

		const overlay = document.createElement("div");
		overlay.id = zoomViewerOverlayId;
		overlay.dataset.zoomViewerOverlay = "true";
		overlay.setAttribute("role", "dialog");
		overlay.setAttribute("aria-modal", "true");
		overlay.setAttribute("aria-label", label);

		const stage = document.createElement("div");
		stage.className = "zoom-viewer__stage";

		const controls = document.createElement("div");
		controls.className = "zoom-viewer__controls";

		const zoomOutButton = document.createElement("button");
		zoomOutButton.type = "button";
		zoomOutButton.className = "zoom-viewer__button";
		zoomOutButton.setAttribute("aria-label", "缩小");
		zoomOutButton.title = "缩小";
		zoomOutButton.textContent = "-";

		const resetButton = document.createElement("button");
		resetButton.type = "button";
		resetButton.className = "zoom-viewer__button";
		resetButton.setAttribute("aria-label", "重置缩放");
		resetButton.title = "重置缩放";
		resetButton.textContent = "1:1";

		const zoomInButton = document.createElement("button");
		zoomInButton.type = "button";
		zoomInButton.className = "zoom-viewer__button";
		zoomInButton.setAttribute("aria-label", "放大");
		zoomInButton.title = "放大";
		zoomInButton.textContent = "+";

		const closeButton = document.createElement("button");
		closeButton.type = "button";
		closeButton.className = "zoom-viewer__button";
		closeButton.setAttribute("aria-label", "关闭预览");
		closeButton.title = "关闭预览";
		closeButton.textContent = "×";
		closeButton.addEventListener("click", () => closeZoomViewer());

		controls.append(zoomOutButton, resetButton, zoomInButton, closeButton);
		stage.appendChild(content);
		overlay.append(controls, stage);
		overlay.addEventListener("click", (event) => {
			if (event.target === overlay) {
				closeZoomViewer();
			}
		});

		document.body.appendChild(overlay);
		document.documentElement.classList.add("zoom-viewer-open");
		document.addEventListener("keydown", onZoomViewerKeydown);
		requestAnimationFrame(() => overlay.classList.add("is-open"));

		if (content instanceof HTMLImageElement) {
			await waitForImage(content);
		}

		const panzoom = Panzoom(content, {
			cursor: "grab",
			maxScale: 8,
			minScale: 0.25,
			panOnlyWhenZoomed: false,
			duration: 220,
			easing: "cubic-bezier(0.2, 0, 0.2, 1)",
			step: 0.35,
		});
		const zoomWithWheel = panzoom.zoomWithWheel;
		stage.addEventListener("wheel", zoomWithWheel, { passive: false });
		zoomOutButton.addEventListener("click", () => panzoom.zoomOut({ animate: true }));
		resetButton.addEventListener("click", () => panzoom.reset({ animate: true }));
		zoomInButton.addEventListener("click", () => panzoom.zoomIn({ animate: true }));
		destroyActiveZoomViewer = () => {
			stage.removeEventListener("wheel", zoomWithWheel);
			panzoom.destroy();
		};

		closeButton.focus();
	}

	function bindImageZoom() {
		document.querySelectorAll<HTMLImageElement>(".prose img:not(#logo)").forEach((image) => {
			if (image.dataset.zoomViewerBound === "true") {
				return;
			}

			image.dataset.zoomViewerBound = "true";
			image.setAttribute("title", "点击放大图片");
			image.addEventListener("click", (event) => {
				event.preventDefault();

				const clone = image.cloneNode(false) as HTMLImageElement;
				clone.removeAttribute("id");
				clone.classList.add("zoom-viewer__content", "zoom-viewer__content--image");
				clone.draggable = false;

				void openZoomViewer(clone, image.alt ? `图片预览：${image.alt}` : "图片预览");
			});
		});
	}

	function bindMermaidZoom() {
		document.querySelectorAll<SVGSVGElement>("pre.mermaid svg").forEach((svg) => {
			const container = svg.closest<HTMLElement>("pre.mermaid");
			if (!container || container.dataset.zoomViewerBound === "true") {
				return;
			}

			container.dataset.zoomViewerBound = "true";
			container.setAttribute("title", "点击放大图表");
			container.addEventListener("click", () => {
				const clone = svg.cloneNode(true) as SVGSVGElement;
				const intrinsicWidth = Math.ceil(getSvgViewBoxWidth(svg));
				const viewerWidth = Math.min(Math.max(intrinsicWidth * 1.5, 1200), 3200);
				clone.removeAttribute("width");
				clone.removeAttribute("height");
				clone.classList.add("zoom-viewer__content", "zoom-viewer__content--mermaid");
				clone.style.width = `${viewerWidth}px`;
				clone.style.maxWidth = "none";

				void openZoomViewer(clone, "图表预览");
			});
		});
	}

	function bindZoomTargets() {
		bindImageZoom();
		bindMermaidZoom();
	}

	bindZoomTargets();
	window.addEventListener("load", bindZoomTargets);
	new MutationObserver(bindZoomTargets).observe(document.body, { childList: true, subtree: true });

	const scrollBtn = document.getElementById("to-top-btn") as HTMLButtonElement;
	const targetHeader = document.getElementById("blog-hero") as HTMLDivElement;

	function callback(entries: IntersectionObserverEntry[]) {
		entries.forEach((entry) => {
			// only show the scroll to top button when the heading is out of view
			scrollBtn.dataset.show = (!entry.isIntersecting).toString();
		});
	}

	scrollBtn.addEventListener("click", () => {
		document.documentElement.scrollTo({ top: 0, behavior: "smooth" });
	});

	const observer = new IntersectionObserver(callback);
	observer.observe(targetHeader);
</script>
